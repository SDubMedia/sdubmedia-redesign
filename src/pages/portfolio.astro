---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Portfolio | SDub Media Nashville" description="Work from SDub Media: corporate video, recurring content, weddings, and events in Nashville.">
<section>
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Our work</span>
      <h1>Portfolio</h1>
      <p style="max-width: 560px; margin-top: 1rem;">A selection of work from our Nashville clients. Full portfolio available on request.</p>
    </div>
    <p style="color: var(--muted);">Videos coming soon.</p>
  </div>
</section>
</Layout>
