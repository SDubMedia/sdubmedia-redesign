---
import Layout from '../layouts/Layout.astro';

// ── HOW TO ADD A VIDEO ──────────────────────────────────────────────
// Fill in an item below. `youtube` is just the ID from the URL:
//   https://www.youtube.com/watch?v=ABC123xyz   →   youtube: 'ABC123xyz'
//   https://youtu.be/ABC123xyz                  →   youtube: 'ABC123xyz'
// Leave `youtube` as '' to show a styled "Coming soon" placeholder tile.
// Only use REAL clients from the approved list. No invented names.
// ────────────────────────────────────────────────────────────────────
interface PortfolioItem {
  title: string;
  client: string;   // real client name, or '' to omit
  category: string;  // e.g. 'Corporate', 'Event', 'Wedding', 'Brand'
  youtube: string;   // YouTube video ID, or '' for a placeholder tile
}

const items: PortfolioItem[] = [
  { title: 'Coming soon', client: '', category: 'Corporate', youtube: '' },
  { title: 'Coming soon', client: '', category: 'Event', youtube: '' },
  { title: 'Coming soon', client: '', category: 'Brand', youtube: '' },
  { title: 'Coming soon', client: '', category: 'Wedding', youtube: '' },
  { title: 'Coming soon', client: '', category: 'Recurring content', youtube: '' },
  { title: 'Coming soon', client: '', category: 'Event', youtube: '' },
];
---
<Layout title="Portfolio | SDub Media Nashville" description="Work from SDub Media: corporate video, recurring content, weddings, and events in Nashville.">
<section>
  <div class="container">
    <div class="section-head">
      <span class="eyebrow">Our work</span>
      <h1>Portfolio</h1>
      <p style="max-width: 560px; margin: 1rem auto 0;">A selection of work from our Nashville clients. Full portfolio available on request.</p>
    </div>

    <div class="pf-grid">
      {items.map(item => (
        item.youtube ? (
          <button class="pf-card" data-yt={item.youtube} aria-label={`Play ${item.title}`}>
            <span
              class="pf-thumb"
              style={`background-image: url(https://i.ytimg.com/vi/${item.youtube}/hqdefault.jpg)`}
            >
              <span class="pf-play" aria-hidden="true">▶</span>
            </span>
            <span class="pf-meta">
              <span class="pf-cat">{item.category}</span>
              <span class="pf-title">{item.title}</span>
              {item.client && <span class="pf-client">{item.client}</span>}
            </span>
          </button>
        ) : (
          <div class="pf-card pf-empty">
            <span class="pf-thumb pf-thumb-empty"><span class="pf-soon">Coming soon</span></span>
            <span class="pf-meta">
              <span class="pf-cat">{item.category}</span>
            </span>
          </div>
        )
      ))}
    </div>

    <p style="text-align: center; margin-top: 3rem; color: var(--muted);">
      Want to see more? <a href="/contact">Get in touch</a> and we'll send work that matches what you're planning.
    </p>
  </div>
</section>

<style>
  .pf-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .pf-card {
    display: block;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    text-align: left;
    padding: 0;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    color: var(--text);
    font: inherit;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .pf-card:hover { border-color: var(--border-strong); }
  .pf-empty { cursor: default; }

  .pf-thumb {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    background-color: var(--bg-elevated);
  }
  .pf-thumb-empty {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pf-soon { color: var(--muted); font-size: 0.8rem; letter-spacing: 0.05em; text-transform: uppercase; }

  .pf-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 56px; height: 56px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(12, 18, 32, 0.7);
    border: 1px solid var(--brand);
    border-radius: 50%;
    color: var(--brand);
    font-size: 1.1rem;
    padding-left: 4px;
    transition: background 0.15s, transform 0.15s;
  }
  .pf-card:hover .pf-play { background: var(--brand); color: #0c1220; transform: translate(-50%, -50%) scale(1.06); }

  .pf-meta { display: block; padding: 1rem 1.25rem 1.25rem; }
  .pf-cat { display: block; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--brand); margin-bottom: 0.35rem; }
  .pf-title { display: block; font-weight: 600; letter-spacing: -0.01em; }
  .pf-client { display: block; font-size: 0.85rem; color: var(--muted); margin-top: 0.15rem; }

  .pf-frame { width: 100%; aspect-ratio: 16 / 9; border: 0; display: block; }
</style>

<script>
  // Click-to-play facade: swap the thumbnail for an autoplaying iframe only
  // when the visitor clicks, so the page stays light and nothing loads from
  // YouTube until asked.
  document.querySelectorAll('.pf-card[data-yt]').forEach(card => {
    card.addEventListener('click', () => {
      const id = card.getAttribute('data-yt');
      if (!id) return;
      const thumb = card.querySelector('.pf-thumb');
      if (!thumb) return;
      const iframe = document.createElement('iframe');
      iframe.className = 'pf-frame';
      iframe.src = `https://www.youtube.com/embed/${id}?autoplay=1&rel=0`;
      iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
      iframe.setAttribute('allowfullscreen', '');
      thumb.replaceWith(iframe);
    }, { once: true });
  });
</script>
</Layout>
