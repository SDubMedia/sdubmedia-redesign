---
import Layout from '../layouts/Layout.astro';
---
<Layout title="About | SDub Media Nashville" description="SDub Media is a Nashville video production company focused on recurring content for businesses.">
<section>
  <div class="container-narrow text-center">
    <span class="eyebrow">About</span>
    <h1>One team. One system.<br>Same quality every week.</h1>
    <p style="font-size: 1.1rem; margin-top: 1.5rem;">SDub Media is a Nashville video production company built around one idea: businesses need to show up on video consistently, not just once. We build the production system so your content actually gets made, week after week, without the chaos.</p>
    <p>Based in Nashville, TN. Serving businesses across Middle Tennessee and beyond.</p>
    <div style="margin-top: 2.5rem;">
      <a href="/contact" class="btn btn-primary">Get in touch</a>
    </div>
  </div>
</section>
</Layout>
