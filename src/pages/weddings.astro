---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Nashville Wedding Videographer | SDub Media" description="Cinematic wedding films and portrait sessions in Nashville. Limited bookings each year.">
<section>
  <div class="container-narrow">
    <span class="eyebrow">Weddings &amp; Portraits</span>
    <h1>Eight weddings a year.<br>Every one deliberate.</h1>
    <p style="font-size: 1.1rem; margin-top: 1.5rem;">We limit wedding bookings so every film gets the time it deserves. Cinematic wedding films, family sessions, and senior portraits. Nashville, destination, or wherever you're celebrating.</p>
    <div style="margin-top: 2.5rem;">
      <a href="/contact" class="btn btn-primary">Check availability</a>
    </div>
  </div>
</section>
</Layout>
